# OS / editor cruft
.DS_Store
*.swp
*~
.idea/
.vscode/

# Python
__pycache__/
*.pyc
.venv/

# Local cask authoring scratch (cask-master.sh writes here, outside the repo by default)
/tmp/caskwork/
caskwork/

# Transient per-chunk sourcing scratch — consolidated into progress/sourced/*-results.tsv
# (and folded into master-list.csv) when a run completes, so the per-chunk files aren't tracked.
progress/sourced/in-*.tsv
progress/sourced/out-*.tsv

# Local-only Claude settings (keep shared skills tracked; ignore personal settings)
.claude/settings.local.json
