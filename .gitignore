# OS / editor cruft
.DS_Store
*.swp
*~
.idea/
.vscode/

# Python
__pycache__/
*.pyc
.venv/

# Local cask authoring scratch (cask-master.sh writes here, outside the repo by default)
/tmp/caskwork/
caskwork/

# Transient per-chunk sourcing/authoring scratch — consolidated into progress/sourced/*-results.tsv
# and folded into master-list.csv / cask-master.sh when a run completes, so they aren't tracked.
progress/sourced/in-*.tsv
progress/sourced/out-*.tsv
progress/sourced/funcs-*.sh

# Local-only Claude settings (keep shared skills tracked; ignore personal settings)
.claude/settings.local.json
